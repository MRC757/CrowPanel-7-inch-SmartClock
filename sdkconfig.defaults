# Smart Clock — ESP32-S3 SDK configuration overrides
#
# Resets the GDMA channel at the start of every vertical blanking interval.
# This prevents the Panel_RGB scan pointer from drifting when the CPU or other
# DMA activity (Serial, I2C, WiFi) briefly starves the LCD_CAM engine, which
# manifests as the image shifting left/right on screen.
CONFIG_LCD_RGB_RESTART_IN_VSYNC=y

# Keep small heap allocations in internal SRAM instead of routing them to PSRAM.
# The ESP32-S3 PSRAM bus is shared by LCD_CAM GDMA (continuous front-buffer reads)
# and the CPU D-cache (back-buffer writes during flush).  When WiFi DMA, LwIP
# packet buffers, or ArduinoJson heap documents also land in PSRAM all three
# masters compete for the same bus, causing visible horizontal jitter.
#
# Threshold set to 8 KB (not 16 KB) to prevent SSL heap exhaustion:
# mbedTLS allocates two 16 KB SSL record buffers per connection via regular
# malloc().  At threshold=16384 these land in internal SRAM; after 3 news +
# 6 stock SSL connections the SRAM heap fragments until the hardware SHA DMA
# buffer (tiny, but needs contiguous SRAM) can no longer be allocated, causing
# "esp-sha: Failed to allocate buf memory" and all subsequent SSL connections
# to fail permanently until reboot.
# At threshold=8192 the 16 KB record buffers go to PSRAM instead.  WiFi and
# LwIP use explicit MALLOC_CAP_INTERNAL|DMA caps and are unaffected.
# Small jitter-sensitive allocations (≤8 KB) still stay in SRAM.
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=8192
