# Smart Clock — ESP32-S3 SDK configuration overrides
#
# Resets the GDMA channel at the start of every vertical blanking interval.
# This prevents the Panel_RGB scan pointer from drifting when the CPU or other
# DMA activity (Serial, I2C, WiFi) briefly starves the LCD_CAM engine, which
# manifests as the image shifting left/right on screen.
CONFIG_LCD_RGB_RESTART_IN_VSYNC=y

# Keep small heap allocations in internal SRAM instead of routing them to PSRAM.
# The ESP32-S3 PSRAM bus is shared by LCD_CAM GDMA (continuous front-buffer reads)
# and the CPU D-cache (back-buffer writes during flush).  When WiFi DMA, LwIP
# packet buffers, or ArduinoJson heap documents also land in PSRAM all three
# masters compete for the same bus, causing visible horizontal jitter.
#
# Threshold set to 4 KB to prevent SSL heap exhaustion after multiple connections:
# mbedTLS allocates per-connection via regular malloc():
#   - Two 16 KB SSL record buffers (RX/TX)          → PSRAM (>4 KB)
#   - Certificate chain parse buffers (~4–8 KB)      → PSRAM (>4 KB)
#   - Small context structs + hash buffers (<4 KB)   → SRAM
# With threshold=8192 the 16 KB buffers go to PSRAM, but the ~4–8 KB cert
# buffers still land in SRAM and fragment it; after 6 stock SSL connections
# the alerts fetch fails with "SSL - Memory allocation failed" (-32512).
# At threshold=4096 those mid-size cert buffers also go to PSRAM, leaving
# SRAM only for sub-4 KB allocations where fragmentation is negligible.
# WiFi/LwIP use explicit MALLOC_CAP_INTERNAL|DMA caps and are unaffected.
# All JSON docs use static StaticJsonDocument (BSS, not heap) — unaffected.
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=4096
